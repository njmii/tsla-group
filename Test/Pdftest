<!DOCTYPE html><html><head><meta charset='utf-8'><script src='assets/pdf-lib.min.js'></script><title>BL714 Stage1</title></head><body><h2>BL714 Stage 1</h2><button onclick='generateBL714()'>Generate BL714 Test PDF</button><pre id='s'>Ready</pre><script>async function generateBL714(){try{document.getElementById('s').textContent='Loading';const b=await fetch('assets/bl714form.pdf').then(r=>{if(!r.ok)throw new Error('Cannot load PDF');return r.arrayBuffer()});const d=await PDFLib.PDFDocument.load(b);const p=await d.save();const blob=new Blob([p],{type:'application/pdf'});const u=URL.createObjectURL(blob);const a=document.createElement('a');a.href=u;a.download='BL714-Test.pdf';a.click();URL.revokeObjectURL(u);document.getElementById('s').textContent='Success';}catch(e){document.getElementById('s').textContent=e.message;alert('Generation failed');}}</script></body></html>
